{
  "version": "0.1.0",
  "purpose": "HTML 原型的语义图标索引。本文件不打包最终图标资源，只记录首选来源和回退方式。",
  "sourcePriority": [
    "当前截图或 Page 1 中的 Figma 节点",
    "从 Figma 导出的现有本地资源",
    "带有明确说明的简单低保真占位方案"
  ],
  "fallbackRules": [
    "源图标不可用时不要发明装饰性图标。",
    "不要使用 emoji 作为产品图标。",
    "同一个原型内使用一套一致的占位样式。",
    "如果生产图标缺失，在输出说明中标记为待替换图标。"
  ],
  "icons": [
    {
      "semanticName": "menu",
      "chineseName": "菜单",
      "commonLocations": ["top navigation"],
      "preferredSource": "current Figma page node",
      "fallback": "three-line menu glyph inside the same container size as source"
    },
    {
      "semanticName": "settings",
      "chineseName": "设置",
      "commonLocations": ["filter row", "page toolbar"],
      "preferredSource": "current Figma page node",
      "fallback": "two-line slider placeholder or text-only setting entry"
    },
    {
      "semanticName": "add-watchlist",
      "chineseName": "添加自选",
      "commonLocations": ["summary row", "empty state", "watchlist tools"],
      "preferredSource": "PlusCircleOutlined from Figma if present",
      "fallback": "plus sign in a thin circle"
    },
    {
      "semanticName": "list-tools",
      "chineseName": "列表工具",
      "commonLocations": ["watchlist table header", "market list header"],
      "preferredSource": "current Figma page node",
      "fallback": "small square placeholders matching source spacing"
    },
    {
      "semanticName": "bottom-nav-market",
      "chineseName": "大盘",
      "commonLocations": ["bottom navigation"],
      "preferredSource": "bottom navigation instance from current Figma page",
      "fallback": "single neutral rounded square placeholder"
    },
    {
      "semanticName": "bottom-nav-watchlist",
      "chineseName": "自选",
      "commonLocations": ["bottom navigation"],
      "preferredSource": "bottom navigation instance from current Figma page",
      "fallback": "active rounded square placeholder using accent color"
    },
    {
      "semanticName": "bottom-nav-opportunity",
      "chineseName": "机会",
      "commonLocations": ["bottom navigation"],
      "preferredSource": "bottom navigation instance from current Figma page",
      "fallback": "single neutral rounded square placeholder"
    },
    {
      "semanticName": "bottom-nav-trade",
      "chineseName": "交易",
      "commonLocations": ["bottom navigation"],
      "preferredSource": "bottom navigation instance from current Figma page",
      "fallback": "single neutral rounded square placeholder"
    },
    {
      "semanticName": "advisor-avatar",
      "chineseName": "投顾头像",
      "commonLocations": ["floating advisor entry"],
      "preferredSource": "current Figma page image asset",
      "fallback": "text-only circular entry with icon pending replacement note"
    },
    {
      "semanticName": "stock-market-tag",
      "chineseName": "市场小标签",
      "commonLocations": ["stock list row"],
      "preferredSource": "HTML text tag, not image asset",
      "fallback": "small bordered text tag"
    }
  ]
}
